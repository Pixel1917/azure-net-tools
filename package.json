{
	"name": "@azure-net/tools",
	"type": "module",
	"description": "Azure-net tools library",
	"homepage": "https://github.com/Pixel1917/azure-net-tools",
	"bugs": {
		"url": "https://github.com/Pixel1917/azure-net-tools/issues",
		"email": "sank195951@gmail.com"
	},
	"author": "Sergey Galaktionov",
	"repository": {
		"type": "git",
		"url": "https://github.com/Pixel1917/azure-net-tools.git"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"version": "1.2.1",
	"main": "dist/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/index.js"
		},
		"./environmentUtil": {
			"types": "./dist/types/environmentUtil/EnvironmentUtil.d.ts",
			"default": "./dist/environmentUtil/EnvironmentUtil.js"
		},
		"./environment": {
			"types": "./environment.d.ts",
			"default": "./environment.js"
		},
		"./environment/browser": {
			"types": "./dist/types/environmentUtil/envFlag.d.ts",
			"browser": "./dist/environmentUtil/true.js",
			"development": "./dist/environmentUtil/false.js",
			"production": "./dist/environmentUtil/false.js",
			"default": "./dist/environmentUtil/browser-fallback.js"
		},
		"./environment/development": {
			"types": "./dist/types/environmentUtil/envFlag.d.ts",
			"development": "./dist/environmentUtil/true.js",
			"production": "./dist/environmentUtil/false.js",
			"default": "./dist/environmentUtil/development-fallback.js"
		},
		"./environment/node": {
			"types": "./dist/types/environmentUtil/envFlag.d.ts",
			"node": "./dist/environmentUtil/true.js",
			"default": "./dist/environmentUtil/false.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"environment.js",
		"environment.d.ts"
	],
	"scripts": {
		"build": "tsc",
		"format": "prettier --write 'src/**/*.ts'",
		"lint": "eslint \"src/**/*.ts\"",
		"check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepare": "husky",
		"commit": "pnpm format && git add . && git-cz && git push",
		"pub": "pnpm build && pnpm publish"
	},
	"keywords": [],
	"packageManager": "pnpm@9.13.2+sha512.88c9c3864450350e65a33587ab801acf946d7c814ed1134da4a924f6df5a2120fd36b46aab68f7cd1d413149112d53c7db3a4136624cfd00ff1846a0c6cef48a",
	"devDependencies": {
		"@eslint/js": "^9.25.1",
		"@commitlint/cli": "^19.7.1",
		"@types/node": "^22.15.21",
		"commitizen": "^4.3.1",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.1",
		"git-cz": "^4.9.0",
		"globals": "^16.0.0",
		"happy-dom": "^20.8.9",
		"husky": "^9.1.7",
		"prettier": "^3.5.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.42.0",
		"vitest": "^3.2.4"
	},
	"config": {
		"commitizen": {
			"path": "git-cz"
		}
	}
}
